{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://grove.app/schemas/bundle.schema.json",
  "title": "Grove Bundle",
  "description": "Schema for curriculum/<slug>/bundle.json (v3) — produced by build-bundle.mjs",
  "type": "object",
  "required": ["version", "slug", "bundled", "course", "lessons", "cards", "quizzes", "modchecks", "concepts", "adaptiveRules", "learningPaths", "codeChallenges", "practicalApplications"],
  "additionalProperties": true,
  "properties": {
    "version":  { "type": "string", "const": "3.0" },
    "slug":     { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "bundled":  { "type": "string", "format": "date-time" },
    "course":   { "$ref": "course.schema.json" },
    "learner":  { "type": "object" },
    "lessons": {
      "type": "object",
      "description": "Map of lessonId → rendered markdown string",
      "additionalProperties": { "type": "string" }
    },
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "front", "back", "module", "lesson", "type", "cognitive_level", "weight", "reviewable"],
        "properties": {
          "id":              { "type": "string" },
          "front":           { "type": "string" },
          "back":            { "type": "string" },
          "module":          { "type": "string" },
          "lesson":          { "type": "string" },
          "type":            { "type": "string" },
          "source_ref":      { "type": "string" },
          "concepts":        { "type": "array", "items": { "type": "string" } },
          "cognitive_level": { "type": "string", "enum": ["recall","comprehension","application"] },
          "weight":          { "type": "number", "minimum": 0, "maximum": 1 },
          "reviewable":      { "type": "boolean" }
        }
      }
    },
    "quizzes": {
      "type": "object",
      "description": "Map of moduleId → quiz object with enriched questions",
      "additionalProperties": {
        "type": "object",
        "required": ["module_id", "title", "questions"],
        "properties": {
          "module_id":    { "type": "string" },
          "title":        { "type": "string" },
          "passing_score": { "type": "integer" },
          "questions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "question"],
              "properties": {
                "id":                    { "type": "string" },
                "type":                  { "type": "string", "enum": ["mcq","short_answer","essay"] },
                "question":              { "type": "string" },
                "correct":               { "type": "string" },
                "concepts":              { "type": "array", "items": { "type": "string" } },
                "cognitive_level":       { "type": "string", "enum": ["recall","comprehension","application"] },
                "weight":                { "type": "number" },
                "remediation_lesson_ids": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "modchecks": {
      "type": "object",
      "description": "Map of moduleId → modcheck quiz object (short-answer only)"
    },
    "codeChallenges": {
      "type": "object",
      "description": "Map of moduleId → code challenge collection with coding exercises",
      "additionalProperties": {
        "type": "object",
        "required": ["module_id", "title", "challenges"],
        "properties": {
          "module_id":    { "type": "string" },
          "title":        { "type": "string" },
          "challenges": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "language", "prompt", "starter_code", "test_cases"],
              "properties": {
                "id":                    { "type": "string" },
                "type":                  { "type": "string", "const": "code-challenge" },
                "language":              { "type": "string", "enum": ["python", "javascript"] },
                "prompt":                { "type": "string" },
                "starter_code":          { "type": "string" },
                "test_cases": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "input", "expected_output", "visibility"],
                    "properties": {
                      "name":              { "type": "string" },
                      "input":             { "type": "string" },
                      "expected_output":   { "type": "string" },
                      "visibility":        { "type": "string", "enum": ["visible", "hidden"] }
                    }
                  }
                },
                "concepts":              { "type": "array", "items": { "type": "string" } },
                "cognitive_level":       { "type": "string", "enum": ["application", "synthesis"] },
                "weight":                { "type": "number", "minimum": 0 },
                "difficulty":            { "type": "integer", "minimum": 1, "maximum": 5 },
                "lesson_ref":            { "type": "string" },
                "pass_criteria":         { "type": "number", "minimum": 0, "maximum": 1 },
                "remediation_lesson_ids": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "practicalApplications": {
      "type": "object",
      "description": "Map of moduleId → practical application collection with project or workflow ideas",
      "additionalProperties": {
        "type": "object",
        "required": ["module_id", "title", "applications"],
        "properties": {
          "module_id": { "type": "string" },
          "title": { "type": "string" },
          "applications": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "title", "summary", "prompt", "deliverable", "estimated_minutes", "difficulty", "lesson_refs"],
              "properties": {
                "id": { "type": "string" },
                "type": { "type": "string", "enum": ["project", "implementation", "workflow", "artifact"] },
                "title": { "type": "string" },
                "summary": { "type": "string" },
                "prompt": { "type": "string" },
                "deliverable": { "type": "string" },
                "estimated_minutes": { "type": "number", "minimum": 1 },
                "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
                "lesson_refs": { "type": "array", "items": { "type": "string" } },
                "concepts": { "type": "array", "items": { "type": "string" } },
                "tools": { "type": "array", "items": { "type": "string" } },
                "steps": { "type": "array", "items": { "type": "string" } },
                "success_criteria": { "type": "array", "items": { "type": "string" } },
                "extension_ideas": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "concepts": {
      "type": "object",
      "required": ["slug", "concepts"],
      "properties": {
        "slug":     { "type": "string" },
        "concepts": { "type": "array" }
      }
    },
    "adaptiveRules": {
      "type": "object",
      "properties": {
        "progression_rules": { "type": "object" },
        "review_policy":     { "type": "object" },
        "mastery_defaults":  { "type": "object" },
        "remediation_policy": { "type": "object" }
      }
    },
    "learningPaths": {
      "type": "object",
      "required": ["paths"],
      "properties": {
        "paths": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "description", "lessons"],
            "properties": {
              "id":          { "type": "string" },
              "title":       { "type": "string" },
              "description": { "type": "string" },
              "lessons":     { "type": "array", "items": { "type": "string" } },
              "focus_areas": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
