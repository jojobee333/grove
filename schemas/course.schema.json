{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://grove.app/schemas/course.schema.json",
  "title": "Grove Course",
  "description": "Schema for curriculum/<slug>/course.json (v3)",
  "type": "object",
  "required": ["slug", "topic", "summary", "total_lessons", "total_estimated_hours", "modules", "learning_plan"],
  "additionalProperties": false,
  "properties": {
    "slug":                    { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "topic":                   { "type": "string", "minLength": 1 },
    "summary":                 { "type": "string" },
    "total_lessons":           { "type": "integer", "minimum": 1 },
    "total_estimated_hours":   { "type": "number",  "minimum": 0 },
    "learning_plan": {
      "type": "object",
      "required": ["milestone_lessons", "suggested_schedule"],
      "properties": {
        "milestone_lessons":  { "type": "array", "items": { "type": "string" } },
        "suggested_schedule": { "type": "string" },
        "paths":              { "type": "array", "items": { "type": "string" } }
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "objectives", "lessons"],
        "properties": {
          "id":           { "type": "string", "pattern": "^M\\d+$" },
          "title":        { "type": "string" },
          "description":  { "type": "string" },
          "strata_theme": { "type": "string" },
          "objectives":   { "type": "array", "items": { "type": "string" } },
          "has_assessment": { "type": "boolean" },
          "lessons": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "id", "title", "type", "estimated_minutes", "description",
                "prerequisites", "teaches_concepts", "reinforces_concepts",
                "mastery_threshold", "difficulty", "unlock_rule", "review_after_days"
              ],
              "additionalProperties": true,
              "properties": {
                "id":                  { "type": "string", "pattern": "^L\\d+$" },
                "title":               { "type": "string" },
                "type":                { "type": "string", "enum": ["core","applied","debate","gap","synthesis","context","overview","advanced"] },
                "estimated_minutes":   { "type": "integer", "minimum": 1 },
                "description":         { "type": "string" },
                "strata_claim":        { "type": "string" },
                "prerequisites":       { "type": "array", "items": { "type": "string" } },
                "teaches_concepts":    { "type": "array", "items": { "type": "string" } },
                "reinforces_concepts": { "type": "array", "items": { "type": "string" } },
                "mastery_threshold":   { "type": "number", "minimum": 0, "maximum": 1 },
                "difficulty":          { "type": "integer", "minimum": 1, "maximum": 5 },
                "unlock_rule":         { "type": "string", "enum": ["all_prerequisites_mastered","any_prerequisite_mastered","always"] },
                "review_after_days":   { "type": "array", "items": { "type": "integer", "minimum": 0 } }
              }
            }
          }
        }
      }
    }
  }
}
