      "type": "code-challenge",
      "language": "rust",
      "prompt": "Write a function `fizzbuzz(n: u32) -> String` that returns `\"FizzBuzz\"` if n is divisible by both 3 and 5, `\"Fizz\"` if divisible by 3 only, `\"Buzz\"` if divisible by 5 only, or the number as a string otherwise. Use `if`/`else if`/`else` — **not** `match`.",
      "starter_code": "fn fizzbuzz(n: u32) -> String {\n    // Return \"FizzBuzz\", \"Fizz\", \"Buzz\", or the number as a String\n    // Use if/else if/else, not match\n    String::new()\n}\n",
      "test_cases": [
