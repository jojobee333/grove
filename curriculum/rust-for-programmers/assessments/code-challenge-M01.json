      "id": "CC01",
      "type": "code-challenge",
      "language": "rust",
      "prompt": "Write a function `celsius_to_fahrenheit(c: f64) -> f64` that converts a Celsius temperature to Fahrenheit. The formula is `F = C × 1.8 + 32`. Round to two decimal places by using `(value * 100.0).round() / 100.0`.",
      "starter_code": "fn celsius_to_fahrenheit(c: f64) -> f64 {\n    // Convert Celsius to Fahrenheit: F = C * 1.8 + 32\n    // Round to 2 decimal places: (value * 100.0).round() / 100.0\n    0.0\n}\n",
      "test_cases": [
        {
          "name": "Freezing point",
          "input": "0.0",
          "expected_output": "32",
          "visibility": "visible"
        },
        {
          "name": "Boiling point",
          "input": "100.0",
          "expected_output": "212",
          "visibility": "visible"
        },
        {
          "name": "Body temperature",
          "input": "37.0",
          "expected_output": "98.6",
          "visibility": "hidden"
        },
        {
          "name": "Negative temperature",
          "input": "-40.0",
          "expected_output": "-40",
          "visibility": "hidden"
        }
      ],
      "concepts": ["fn-signature", "return-type", "scalar-types"],
      "cognitive_level": "application",
      "weight": 1.0,
      "difficulty": 2,
      "lesson_ref": "L03",
      "pass_criteria": 0.75,
      "remediation_lesson_ids": ["L03"]
    },
    {
